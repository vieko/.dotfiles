# FONT: FAMILY
font-family = Berkeley Mono Retina
font-family-bold = Berkeley Mono Medium
font-family-italic = Berkeley Mono Retina Oblique
font-family-bold-italic = Berkeley Mono Medium Oblique

# FONT: SIZE — set per-OS in config-linux (10.5) / config-macos (14)

# CURSOR
cursor-style = block
cursor-style-blink = false
cursor-color = 74ade8
cursor-text = 282c34

# WINDOW
window-theme = dark
window-padding-x = 4
window-padding-y = 4
window-padding-color = extend
window-padding-balance = true
window-inherit-working-directory = true

# Don't prompt "close this terminal?" when a process (e.g. tmux) is running.
confirm-close-surface = false
# No size-overlay popup when resizing (noise on tiling WMs; harmless on macOS).
resize-overlay = never

# THEME
# Options: "One Half Dark", "Atom One Dark", "Doom One", "One Double Dark"
theme = One Half Dark

# SHELL
shell-integration = bash

# KEYBINDINGS
# Send ESC+DEL on Alt+Backspace so TUIs (Pi, nvim, readline) see a word-delete
# event instead of a single backspace. Recommended by pi.dev/docs/latest/terminal-setup.
keybind = alt+backspace=text:\x1b\x7f

# MOUSE
mouse-hide-while-typing = true
copy-on-select = clipboard

# URL
link-url = true

# NOTIFICATIONS
# Disable default bell sound — custom sounds via Claude Code Notification hook
bell-features = no-system,no-audio,no-attention,no-title,no-border

# SCROLLBACK
scrollback-limit = 10000

# CLIPBOARD
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true

# TMUX INTEGRATION
# Enable true color support
term = xterm-ghostty

# Shell integration features
# NOTE: Using "no-cursor" to prevent shell from overriding cursor-style setting
# The cursor feature allows shell/vim to change cursor shape, but prevents
# our cursor-style=block and cursor-style-blink=false from working on startup
shell-integration-features = no-cursor

# OS-SPECIFIC SETTINGS
# Ghostty supports config includes via `config-file`. This pulls in the
# per-OS overrides (font-size, window decorations, single-instance, …).
# config-current is a per-machine symlink (gitignored) created by
# setup-os-link.sh, pointing at config-linux or config-macos.
# Kept LAST so OS values override the shared defaults above.
config-file = config-current
