# macOS-specific settings
# Override base config defaults for macOS
# Based on kitty/.config/kitty/os-macos.conf

# macOS font size (larger for Retina displays)
font-size = 14

# macOS window and display options
macos-non-native-fullscreen = false
# Keep the single instance resident after the last window closes so the
# `global:super+return=new_window` hotkey always has a process to target
# (no cold relaunch = no new process = no Screen Recording prompt).
quit-after-last-window-closed = false
macos-option-as-alt = true
# Hidden titlebar = native frame + rounded corners with no title bar (this was
# the prior base-config behavior). Change to `native` for the full title bar.
macos-titlebar-style = hidden

# Window decoration (show full title bar on macOS)
window-decoration = true
