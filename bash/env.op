# 1Password env-file resolved by `op inject` / `op run`.
#
# Values are 1Password URIs — NOT secrets. Safe to commit.
#
# Ambient loading (default): .bashrc runs `op inject` at shell startup so
# every key below is in the parent shell env for the whole session.
#
# Scoped invocation (optional): `opr <cmd>` expands to `op run --env-file=…`
# and injects the env into a child process only. Use for one-off commands
# where you DON'T want the shell env to leak — e.g. running untrusted tools.
#   opr some-sketchy-script
#
# Add a new secret:
#   1. Create/locate the item in 1Password
#   2. Append a line here: KEY=<1Password URI>
#   3. Confirm:           op read "<1Password URI>"
#   4. `source ~/.bashrc` (or new terminal) to pick up the new value
#
# (Note: 1Password URIs in comments must be avoided — `op inject`
# scans for them anywhere in the file and errors on placeholders.)

# === LOCAL
AI_GATEWAY_API_KEY=op://Employee/ai-gateway-pi-on-phyrexia/credential
ANTHROPIC_AUTH_TOKEN=op://Employee/ai-gateway-cc-on-phyrexia/credential
NPM_TOKEN=op://Employee/npm-on-phyrexia/credential
LINEAR_API_KEY=op://Employee/linear-on-phyrexia/credential
NEON_API_KEY=op://Employee/neon-on-phyrexia/credential

